APP_NAME="Image Translator API"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/image_translator
AUTO_CREATE_TABLES=false

CELERY_TASK_ALWAYS_EAGER=true
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
PUBLIC_USER_EMAIL=public@imagetranslator.local
PUBLIC_USER_DISPLAY_NAME="Public Workspace"

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/data/storage
PUBLIC_BASE_URL=http://localhost:8000

# Optional S3-compatible storage settings. Install the `s3` extra and set
# STORAGE_BACKEND=s3 before using these.
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=image-translator
# S3_REGION=us-east-1

MAX_UPLOAD_MB=100
MAX_PROJECT_PAGES=300
ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/webp
ALLOWED_ARCHIVE_TYPES=application/zip,application/x-zip-compressed

OCR_PROVIDER=mock
TRANSLATION_PROVIDER=mock
RENDER_ENGINE=pillow

OPENAI_API_KEY=
DEEPL_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

LOG_LEVEL=INFO
