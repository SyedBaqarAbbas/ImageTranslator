APP_NAME="Image Translator API"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/image_translator
AUTO_CREATE_TABLES=false

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/data/storage
PUBLIC_BASE_URL=http://localhost:8000

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=image-translator
S3_REGION=us-east-1

MAX_UPLOAD_MB=100
MAX_PROJECT_PAGES=300
ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/webp
ALLOWED_ARCHIVE_TYPES=application/zip,application/x-zip-compressed

OCR_PROVIDER=mock
TRANSLATION_PROVIDER=mock
RENDER_ENGINE=pillow

OPENAI_API_KEY=
DEEPL_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

LOG_LEVEL=INFO

