APP_NAME="Image Translator API"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/image_translator
AUTO_CREATE_TABLES=false

CELERY_TASK_ALWAYS_EAGER=true
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
PUBLIC_USER_EMAIL=public@imagetranslator.local
PUBLIC_USER_DISPLAY_NAME="Public Workspace"

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/data/storage
PUBLIC_BASE_URL=http://localhost:8000

# Optional S3-compatible storage settings. Install the `s3` extra and set
# STORAGE_BACKEND=s3 before using these.
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=image-translator
# S3_REGION=us-east-1

MAX_UPLOAD_MB=100
MAX_PROJECT_PAGES=300
ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/webp
ALLOWED_ARCHIVE_TYPES=application/zip,application/x-zip-compressed

OCR_PROVIDER=mock
TRANSLATION_PROVIDER=mock
RENDER_ENGINE=pillow

# Optional local prototype providers. Defaults above remain mock.
# Tesseract requires the native binary and tessdata_fast language files.
# On macOS: brew install tesseract tesseract-lang
# OCR_PROVIDER=tesseract
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
# TESSERACT_DATA_PATH=/opt/homebrew/share/tessdata
# TESSERACT_DEFAULT_LANGUAGE=kor
# TESSERACT_AUTO_LANGUAGE=kor+jpn
# TESSERACT_PSM=6
# TESSERACT_OEM=1
# TESSERACT_PREPROCESS=true
# TESSERACT_UPSCALE_MIN_DIMENSION=0
# TESSERACT_UPSCALE_MAX_FACTOR=2.0
# TESSERACT_THRESHOLD=180
#
# OPUS-MT CTranslate2 expects pre-converted local int8 model directories.
# TRANSLATION_PROVIDER=opus_mt
# OPUS_MT_MODEL_ROOT=/app/models/opus-mt
# OPUS_MT_KO_EN_MODEL_PATH=/app/models/opus-mt/ko-en
# OPUS_MT_JA_EN_MODEL_PATH=/app/models/opus-mt/ja-en
# OPUS_MT_DEFAULT_SOURCE_LANGUAGE=kor
# OPUS_MT_COMPUTE_TYPE=int8
# OPUS_MT_BEAM_SIZE=1
# OPUS_MT_INTRA_THREADS=2
# OPUS_MT_INTER_THREADS=1
# OPUS_MT_MAX_BATCH_SIZE=4

OPENAI_API_KEY=
DEEPL_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

LOG_LEVEL=INFO
